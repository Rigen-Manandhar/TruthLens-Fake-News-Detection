# Copy to .env.local for local development.
# Keep real secrets only in local/private env files.

MONGO_URL=mongodb://localhost:27017/truthlens

# NextAuth / app secrets (use long random values in production)
NEXTAUTH_SECRET=replace-with-a-long-random-secret
AUTH_SECRET=replace-with-a-long-random-secret
NEXTAUTH_URL=http://localhost:3000

# OAuth (optional if not using Google login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# External APIs
NEWS_API_KEY=

# Internal job endpoint protection
MAINTENANCE_API_KEY=replace-with-maintenance-key

# Backend FastAPI URL
BACKEND_URL=http://127.0.0.1:8000
