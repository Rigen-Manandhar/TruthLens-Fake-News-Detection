# Copy to .env.local for local development.
# Keep real secrets only in local/private env files.

MONGO_URL=mongodb://localhost:27017/truthlens

# NextAuth / app secrets (use long random values in production)
NEXTAUTH_SECRET=replace-with-a-long-random-secret
AUTH_SECRET=replace-with-a-long-random-secret
NEXTAUTH_URL=http://localhost:3000

# OAuth (optional if not using Google login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# External APIs
NEWS_API_KEY=

# Internal job endpoint protection
MAINTENANCE_API_KEY=replace-with-maintenance-key

# Backend FastAPI URL
BACKEND_URL=http://127.0.0.1:8000

# Contact form SMTP delivery
# Gmail example:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_USER=your-gmail-address
# SMTP_PASS=your-app-password
# CONTACT_FROM_EMAIL=your-gmail-address
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
CONTACT_FROM_EMAIL=
