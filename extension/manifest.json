{
  "manifest_version": 3,
  "name": "TruthLens",
  "description": "Analyze content for misinformation with TruthLens hybrid detection.",
  "version": "1.0.1",
  "action": {
    "default_title": "TruthLens",
    "default_popup": "popup.html"
  },
  "permissions": ["storage"],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "icons": {
    "16": "assets/icon16.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  }
}
